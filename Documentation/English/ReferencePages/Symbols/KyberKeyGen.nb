Cell[CellGroupData[{
Cell["KyberKeyGen", "ObjectName",
 CellID->354800,ExpressionUUID->"3a59cd3f-aa84-484c-8c9d-bc7e37876e48"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"3fab6d8f-ca3a-4f55-b332-d01a6142e0c3"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["KyberKeyGen",
    BaseStyle->"Link",
    ButtonData->"paclet:ToneAr/Kyber/ref/KyberKeyGen"], "[", 
   StyleBox["level", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "769b3eec-e8e5-4657-8186-c94752bc9327"],
 " \[LineSeparator]generates an ML-KEM (CRYSTALS-Kyber) key pair at the \
specified security ",
 Cell[BoxData[
  StyleBox["level", "TI"]], "InlineFormula",ExpressionUUID->
  "a1b2c3d4-e5f6-7890-abcd-ef1234567890"],
 "."
}], "Usage",
 CellChangeTimes->{{3.9, 4.}},
 CellID->1205012398,ExpressionUUID->"e2e44746-ae14-4e5d-a9e0-96d6931afd9e"],

Cell[TextData[{
 Cell[BoxData[
  StyleBox["level", "TI"]], "InlineFormula",ExpressionUUID->
  "b2c3d4e5-f6a7-8901-bcde-f12345678901"],
 " can be 512, 768, or 1024. The default is 768."
}], "Notes",
 CellID->1323799617,ExpressionUUID->"5d730285-a06f-4070-8b0f-2328ea865fe6"],

Cell["The returned association contains two keys:", "Notes",
 CellID->1323799618,ExpressionUUID->"c3d4e5f6-a7b8-9012-cdef-123456789012"],

Cell[TextData[{
 "\"PublicKey\": ",
 Cell[BoxData[
  ButtonBox["PublicKey",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "d4e5f6a7-b8c9-0123-defa-234567890123"],
 " object suitable for ",
 Cell[BoxData[
  ButtonBox["KyberEncapsulate",
   BaseStyle->"Link",
   ButtonData->"paclet:ToneAr/Kyber/ref/KyberEncapsulate"]], "InlineFormula",
  ExpressionUUID->"e5f6a7b8-c9d0-1234-efab-345678901234"],
 "."
}], "Notes",
 CellChangeTimes->{{3.981661886837226*^9, 3.981661900756052*^9}},
 CellID->1323799619,ExpressionUUID->"f6a7b8c9-d0e1-2345-fabc-456789012345"],

Cell[TextData[{
 "\"PrivateKey\": ",
 Cell[BoxData[
  ButtonBox["PrivateKey",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "a7b8c9d0-e1f2-3456-abcd-567890123456"],
 " object suitable for ",
 Cell[BoxData[
  ButtonBox["KyberDecapsulate",
   BaseStyle->"Link",
   ButtonData->"paclet:ToneAr/Kyber/ref/KyberDecapsulate"]], "InlineFormula",
  ExpressionUUID->"b8c9d0e1-f2a3-4567-bcde-678901234567"],
 "."
}], "Notes",
 CellChangeTimes->{{3.981661904600587*^9, 3.981661905358865*^9}},
 CellID->1323799620,ExpressionUUID->"c9d0e1f2-a3b4-5678-cdef-789012345678"],

Cell["\<\
Security levels correspond to NIST post-quantum security levels: 512 (Level \
1), 768 (Level 3), 1024 (Level 5).\
\>", "Notes",
 CellID->1323799621,ExpressionUUID->"d0e1f2a3-b4c5-6789-defa-890123456789"]
}, Open  ]],

