Cell[CellGroupData[{
Cell["KyberEncapsulate", "ObjectName",
 CellID->657917440,ExpressionUUID->"2cc29406-d3e3-4f65-9fbe-d9e6b1409e97"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"9c6adc77-e25f-4f3c-8c74-9b1aa70bd471"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["KyberEncapsulate",
    BaseStyle->"Link",
    ButtonData->"paclet:ToneAr/Kyber/ref/KyberEncapsulate"], "[",
   StyleBox["publicKey", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "f7f9fc91-cdb0-4f42-9b20-5a64cca692e9"],
 " \[LineSeparator]encapsulates a shared secret using the given ",
 Cell[BoxData[
  StyleBox["publicKey", "TI"]], "InlineFormula",ExpressionUUID->
  "20000001-0000-0000-0000-000000000001"],
 "."
}], "Usage",
 CellChangeTimes->{{3.9, 4.0}},
 CellID->2079726609,ExpressionUUID->"b6a05b2d-5775-46ec-92b5-ee4ae537d7c8"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   ButtonBox["KyberEncapsulate",
    BaseStyle->"Link",
    ButtonData->"paclet:ToneAr/Kyber/ref/KyberEncapsulate"], "[",
   RowBox[{
    StyleBox["publicKey", "TI"], ",", " ",
    StyleBox["level", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "20000002-0000-0000-0000-000000000002"],
 " encapsulates a shared secret at the specified security ",
 Cell[BoxData[
  StyleBox["level", "TI"]], "InlineFormula",ExpressionUUID->
  "20000003-0000-0000-0000-000000000003"],
 " when ",
 Cell[BoxData[
  StyleBox["publicKey", "TI"]], "InlineFormula",ExpressionUUID->
  "20000004-0000-0000-0000-000000000004"],
 " is a ",
 Cell[BoxData[
  ButtonBox["ByteArray",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "20000005-0000-0000-0000-000000000005"],
 "."
}], "Notes",
 CellID->1121720539,ExpressionUUID->"31c6a6bf-8cb8-44e6-bfa8-d00149f8882d"],

Cell[TextData[{
 "When ",
 Cell[BoxData[
  StyleBox["publicKey", "TI"]], "InlineFormula",ExpressionUUID->
  "20000006-0000-0000-0000-000000000006"],
 " is a ",
 Cell[BoxData[
  ButtonBox["PublicKey",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "20000007-0000-0000-0000-000000000007"],
 " object (as returned by ",
 Cell[BoxData[
  ButtonBox["KyberKeyGen",
   BaseStyle->"Link",
   ButtonData->"paclet:ToneAr/Kyber/ref/KyberKeyGen"]], "InlineFormula",
  ExpressionUUID->"20000008-0000-0000-0000-000000000008"],
 "), the security level is determined automatically from the key."
}], "Notes",
 CellID->1121720540,ExpressionUUID->"20000009-0000-0000-0000-000000000009"],

Cell["The returned association contains:", "Notes",
 CellID->1121720541,ExpressionUUID->"20000010-0000-0000-0000-000000000010"],

Cell[TextData[{
 "\"CipherText\" \[Rule] an ",
 Cell[BoxData[
  ButtonBox["EncryptedObject",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "20000011-0000-0000-0000-000000000011"],
 " to be sent to the private key holder."
}], "Notes",
 CellID->1121720542,ExpressionUUID->"20000012-0000-0000-0000-000000000012"],

Cell[TextData[{
 "\"SharedSecret\" \[Rule] a ",
 Cell[BoxData[
  ButtonBox["SymmetricKey",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "20000013-0000-0000-0000-000000000013"],
 " that can be used for symmetric encryption."
}], "Notes",
 CellID->1121720543,ExpressionUUID->"20000014-0000-0000-0000-000000000014"],

Cell["The cipher for the SymmetricKey is AES128 for Kyber-512, and AES256 for \
Kyber-768 and Kyber-1024.", "Notes",
 CellID->1121720544,ExpressionUUID->"20000015-0000-0000-0000-000000000015"]
}, Open  ]],

