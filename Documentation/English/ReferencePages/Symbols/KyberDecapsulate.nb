Cell[CellGroupData[{
Cell["KyberDecapsulate", "ObjectName",
 CellID->1305903905,ExpressionUUID->"321365b9-3895-4da2-be2d-f3cf3f0b8136"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"5738d476-e420-469c-899d-72b3f92dd5b0"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["KyberDecapsulate",
    BaseStyle->"Link",
    ButtonData->"paclet:ToneAr/Kyber/ref/KyberDecapsulate"], "[", 
   RowBox[{
    StyleBox["cipherText", "TI"], ",", " ", 
    StyleBox["privateKey", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "4ed2c0ce-e689-4e80-a509-ef97524f178f"],
 " \[LineSeparator]recovers the shared secret from ",
 Cell[BoxData[
  StyleBox["cipherText", "TI"]], "InlineFormula",ExpressionUUID->
  "50000001-0000-0000-0000-000000000001"],
 " using the recipient\[CloseCurlyQuote]s ",
 Cell[BoxData[
  StyleBox["privateKey", "TI"]], "InlineFormula",ExpressionUUID->
  "50000002-0000-0000-0000-000000000002"],
 "."
}], "Usage",
 CellChangeTimes->{{3.9, 4.}},
 CellID->1223977839,ExpressionUUID->"b75f6b9e-0898-4440-b791-cf12e77c975c"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{
   ButtonBox["KyberDecapsulate",
    BaseStyle->"Link",
    ButtonData->"paclet:ToneAr/Kyber/ref/KyberDecapsulate"], "[", 
   RowBox[{
    StyleBox["cipherText", "TI"], ",", " ", 
    StyleBox["secretKey", "TI"], ",", " ", 
    StyleBox["level", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "50000003-0000-0000-0000-000000000003"],
 " decapsulates using raw ",
 Cell[BoxData[
  ButtonBox["ByteArray",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "50000004-0000-0000-0000-000000000004"],
 " inputs at the specified security ",
 Cell[BoxData[
  StyleBox["level", "TI"]], "InlineFormula",ExpressionUUID->
  "50000005-0000-0000-0000-000000000005"],
 "."
}], "Notes",
 CellID->645496548,ExpressionUUID->"4edc6713-e551-463d-910d-4585b0a5d130"],

Cell[TextData[{
 "When ",
 Cell[BoxData[
  StyleBox["cipherText", "TI"]], "InlineFormula",ExpressionUUID->
  "50000006-0000-0000-0000-000000000006"],
 " is an ",
 Cell[BoxData[
  ButtonBox["EncryptedObject",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "50000007-0000-0000-0000-000000000007"],
 " and ",
 Cell[BoxData[
  StyleBox["privateKey", "TI"]], "InlineFormula",ExpressionUUID->
  "50000008-0000-0000-0000-000000000008"],
 " is a ",
 Cell[BoxData[
  ButtonBox["PrivateKey",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "50000009-0000-0000-0000-000000000009"],
 " object (as returned by ",
 Cell[BoxData[
  ButtonBox["KyberKeyGen",
   BaseStyle->"Link",
   ButtonData->"paclet:ToneAr/Kyber/ref/KyberKeyGen"]], "InlineFormula",
  ExpressionUUID->"50000010-0000-0000-0000-000000000010"],
 "), the security level is determined automatically."
}], "Notes",
 CellID->645496549,ExpressionUUID->"50000011-0000-0000-0000-000000000011"],

Cell[TextData[{
 "Returns a ",
 Cell[BoxData[
  ButtonBox["SymmetricKey",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "50000012-0000-0000-0000-000000000012"],
 " containing the recovered shared secret."
}], "Notes",
 CellID->645496550,ExpressionUUID->"50000013-0000-0000-0000-000000000013"],

Cell["\<\
The recovered shared secret will match the one produced by the corresponding \
call to KyberEncapsulate.\
\>", "Notes",
 CellID->645496551,ExpressionUUID->"50000014-0000-0000-0000-000000000014"]
}, Open  ]],

