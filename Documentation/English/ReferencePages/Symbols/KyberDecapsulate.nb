Cell["\<\
Each encapsulation produces a different ciphertext and shared secret, but \
decapsulation always recovers the correct one:\
\>", "ExampleText",
 CellID->300000020,ExpressionUUID->"60000020-0000-0000-0000-000000000020"],

Cell[BoxData[
 RowBox[{"keys", " ", "=", " ",
  RowBox[{"KyberKeyGen", "[", "]"}]}]], "Input",
