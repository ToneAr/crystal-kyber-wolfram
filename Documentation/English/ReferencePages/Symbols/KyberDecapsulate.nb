Cell["\<\
Generate a key pair, encapsulate a shared secret, then decapsulate it:\
\>", "ExampleText",
 CellID->300000001,ExpressionUUID->"60000001-0000-0000-0000-000000000001"],

Cell[BoxData[
 RowBox[{"keys", " ", "=", " ",
  RowBox[{"KyberKeyGen", "[", "768", "]"}]}]], "Input",
 CellLabel->"In[1]:=",
 CellID->300000002,ExpressionUUID->"60000002-0000-0000-0000-000000000002"],

Cell[BoxData[
 RowBox[{"encap", " ", "=", " ",
  RowBox[{"KyberEncapsulate", "[",
   RowBox[{"keys", "[", "\"\<PublicKey\>\"", "]"}], "]"}]}]], "Input",
 CellLabel->"In[2]:=",
 CellID->300000003,ExpressionUUID->"60000003-0000-0000-0000-000000000003"],

Cell["Recover the shared secret using the private key:", "ExampleText",
 CellID->300000004,ExpressionUUID->"60000004-0000-0000-0000-000000000004"],

Cell[BoxData[
 RowBox[{"decap", " ", "=", " ",
  RowBox[{"KyberDecapsulate", "[",
   RowBox[{
    RowBox[{"encap", "[", "\"\<CipherText\>\"", "]"}], ",", " ",
    RowBox[{"keys", "[", "\"\<PrivateKey\>\"", "]"}]}], "]"}]}]], "Input",
 CellLabel->"In[3]:=",
 CellID->300000005,ExpressionUUID->"60000005-0000-0000-0000-000000000005"],

Cell["Verify the shared secrets are identical:", "ExampleText",
 CellID->300000006,ExpressionUUID->"60000006-0000-0000-0000-000000000006"],

Cell[BoxData[
 RowBox[{
  RowBox[{"encap", "[", "\"\<SharedSecret\>\"", "]"}], " ", "===", " ",
  "decap"}]], "Input",
 CellLabel->"In[4]:=",
 CellID->300000007,ExpressionUUID->"60000007-0000-0000-0000-000000000007"]

}, Open  ]],

